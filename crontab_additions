# Website Sales Pipeline - Daily Automation
# Scrape/enrich/generate (no send) - runs at 3 AM CT (8 AM UTC)
0 8 * * * /root/.local/bin/website-sales-pipeline --skip-send >> /root/.openclaw/workspace/pipeline_scrape.log 2>&1
# Send batches: 7-11 AM CT (12-16 UTC) - 10 emails each
0 12 * * * /root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send_7am.log 2>&1
0 13 * * * /root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send_8am.log 2>&1
0 14 * * * /root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send_9am.log 2>&1
0 15 * * * /root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send_10am.log 2>&1
0 16 * * * /root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send_11am.log 2>&1

# Recursive Improver - runs twice daily at 2 AM & 2 PM CT
0 7,19 * * * /root/.openclaw/workspace/recursive_improver.py >> /root/.openclaw/workspace/improver.log 2>&1
