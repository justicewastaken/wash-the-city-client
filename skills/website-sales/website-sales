#!/usr/bin/env python3
"""
website-sales: End-to-end website sales workflow for local businesses.

Usage:
    website-sales find-leads [options]
    website-sales draft-outreach [options]
    website-sales send-emails [options]
    website-sales generate-payment [options]
    website-sales track-leads [options]
    website-sales schedule-followups [options]

Run 'website-sales <command> --help' for command-specific help.
"""

import sys
import os
import subprocess

# Add skill scripts directory to path
SKILL_DIR = os.path.dirname(os.path.realpath(__file__))
SCRIPTS_DIR = os.path.join(SKILL_DIR, 'scripts')
sys.path.insert(0, SCRIPTS_DIR)

COMMANDS = {
    'find-leads': 'find_leads.py',
    'draft-outreach': 'draft_outreach.py',
    'send-emails': 'send_emails.py',
    'generate-payment': 'generate_payment.py',
    'track-leads': 'track_leads.py',
    'schedule-followups': 'schedule_followups.py'
}

def main():
    if len(sys.argv) < 2:
        print(__doc__)
        print("Available commands:")
        for cmd, script in COMMANDS.items():
            print(f"  {cmd:25} {script}")
        sys.exit(1)

    command = sys.argv[1]
    if command not in COMMANDS:
        print(f"Error: Unknown command '{command}'")
        print("Available commands:", ', '.join(COMMANDS.keys()))
        sys.exit(1)

    script_path = os.path.join(SCRIPTS_DIR, COMMANDS[command])
    # Replace the current process with the script
    os.execvp(sys.executable, [sys.executable, script_path] + sys.argv[2:])

if __name__ == '__main__':
    main()
