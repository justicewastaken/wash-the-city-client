{
  "backup_workspace.sh": {
    "schedule": "0 */2 * * *",
    "command": "/root/.openclaw/workspace/backup_workspace.sh >> /root/.openclaw/workspace/backup.log 2>&1",
    "status": "unknown"
  },
  "security_audit.py": {
    "schedule": "0 13 * * *",
    "command": "/root/.openclaw/workspace/security_audit.py >> /root/.openclaw/workspace/security_audit.log 2>&1",
    "status": "unknown"
  },
  "security_fix.py": {
    "schedule": "30 13 * * *",
    "command": "/root/.openclaw/workspace/security_fix.py >> /root/.openclaw/workspace/security_fix.log 2>&1",
    "status": "unknown"
  },
  "api_health_check.py": {
    "schedule": "0 14 * * *",
    "command": "/root/.openclaw/workspace/api_health_check.py >> /root/.openclaw/workspace/api_health.log 2>&1",
    "status": "unknown"
  },
  "daily_website_batch.py": {
    "schedule": "0 12,13,14,15,16 * * *",
    "command": "/root/.local/bin/website-sales-pipeline --skip-scrape --skip-enrich --batch-size 10 --send >> /root/.openclaw/workspace/pipeline_send.log 2>&1",
    "status": "unknown"
  },
  "recursive_improver.py": {
    "schedule": "0 7,19 * * *",
    "command": "/root/.local/bin/recursive-improver >> /root/.openclaw/workspace/improver.log 2>&1",
    "status": "unknown"
  },
  "website-sales-pipeline (scrape)": {
    "schedule": "0 8 * * *",
    "command": "/root/.local/bin/website-sales-pipeline --skip-send >> /root/.openclaw/workspace/pipeline_scrape.log 2>&1",
    "status": "unknown"
  }
}